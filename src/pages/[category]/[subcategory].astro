---
import Layout from "@/layouts/Layout.astro";
import GridScript from "@/components/GridScript.astro";
import IdleRedirect from "@/components/IdleRedirect.astro";
import {
  getAllSubcategoryPaths,
  getCategoryBySlug,
  getDesignsByCategory,
} from "@/lib/catalogue";

export function getStaticPaths() {
  return getAllSubcategoryPaths().map(({ category, subcategory }) => ({
    params: { category, subcategory },
  }));
}

const { category: catSlug, subcategory: subSlug } = Astro.params;
const cat = getCategoryBySlug(catSlug!);
const subcat = cat?.subcategories?.find((s) => s.slug === subSlug);
if (!subcat) return Astro.redirect("/404");

const designs = getDesignsByCategory(cat!.id, subcat.id);
const ITEMS = 6;
const totalPages = Math.ceil(designs.length / ITEMS);
const title = `${subcat.name} - ${cat!.name} - Logotip`;
---

<Layout {title}>
  <main class="page">
    <div class="page-header">
      <a href={`/${catSlug}`} class="back-btn" aria-label="Inapoi" data-return={`/${catSlug}`}>&larr;&nbsp;Inapoi</a>
      <div style="min-width:0">
        <h1>{subcat.name}</h1>
        <div class="breadcrumb">
          <a href="/">Acas&#259;</a>&nbsp;<span>/</span>&nbsp;
          <a href={`/${catSlug}`}>{cat!.name}</a>&nbsp;<span>/</span>&nbsp;
          <span>{subcat.name}</span>
        </div>
      </div>
    </div>
    <div class="grid-outer" data-total-pages={totalPages}>
      <div class="grid-inner">
        {
          Array.from({ length: totalPages }, (_, p) => (
            <div class={`page-block${p === 0 ? " active" : ""}`} data-page={p + 1}>
              {designs.slice(p * ITEMS, (p + 1) * ITEMS).map((d) => (
                <a href={`/design/${d.id}/`} class="card">
                  <div class="card-img">
                    <img src={d.image} alt={d.name} loading="lazy" />
                  </div>
                  <div class="card-body"><h4>{d.name}</h4></div>
                </a>
              ))}
            </div>
          ))
        }
      </div>
      {totalPages > 1 && (
        <div class="pagination">
          <button class="prev-btn" onclick="goPage(-1)" disabled>&larr;&nbsp;Anterior</button>
          {Array.from({ length: Math.min(totalPages, 5) }, (_, i) => (
            <button data-page={i + 1} onclick={`showPage(${i + 1});updatePagination(${i + 1})`} class={i === 0 ? "active" : ""}>
              {i + 1}
            </button>
          ))}
          <button class="next-btn" onclick="goPage(1)" disabled={totalPages <= 1}>Urm&#259;tor&nbsp;&rarr;</button>
        </div>
      )}
    </div>
  </main>
  <GridScript />
  <IdleRedirect />
</Layout>
